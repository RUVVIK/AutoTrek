<Page x:Class="AutoTrek.Page07_Mechanic"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgLight}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Background="{StaticResource BgDark}" Grid.Row="0">
            <DockPanel>
                <TextBlock Text="Механик" Style="{StaticResource WhiteText}" Margin="20,0" VerticalAlignment="Center" FontSize="16"/>
                <Button Content="Выход" DockPanel.Dock="Right" Background="Transparent" Foreground="White" Click="BtnExit_Click" Margin="0,0,20,0" Width="80"/>
                <StackPanel Orientation="Horizontal" Margin="30,0">
                    <Button Content="Файл" Background="Transparent" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="Справочники" Background="Transparent" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="Запчасти" Background="Transparent" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="Отчёты" Background="Transparent" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="Настройки" Background="Transparent" Foreground="White"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Контент -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel>
                <!-- Кнопки меню -->
                <UniformGrid Columns="3" Height="120" Margin="0,0,0,20">
                    <Button Style="{StaticResource BigBtn}" Content="Ремонты и ТО&#10;Оформление работ" Click="Nav_Click" Tag="Page08_RepairForm"/>
                    <Button Style="{StaticResource BigBtn}" Content="Запчасти&#10;Заявки на приобретение" Click="Nav_Click" Tag="Page09_PartsRequest"/>
                    <Button Style="{StaticResource BigBtn}" Content="История ТС&#10;Просмотр истории обслуживания" Click="Nav_Click" Tag="Page11_ServiceHistory"/>
                </UniformGrid>

                <!-- Панель текущих заявок (ИСПРАВЛЕНО ПОД 2 КОЛОНКИ) -->
                <Border Style="{StaticResource Panel}">
                    <StackPanel>
                        <Border Style="{StaticResource HeaderBar}" CornerRadius="8">
                            <TextBlock Text="Текущие заявки" Style="{StaticResource WhiteText}" TextAlignment="Center"/>
                        </Border>

                        <Grid Margin="0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Левая колонка: Дата и кнопки -->
                            <StackPanel>
                                <TextBlock Text="Сегодня: 28.03.2026" FontSize="14" VerticalAlignment="Center" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Создать заявку" Margin="0,0,5,0"/>
                                    <Button Content="Оформить ремонт" Margin="0,0,5,0"/>
                                    <Button Content="Журнал работ"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Правая колонка: Пустая для выравнивания -->
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Сетка заявок 2 колонки -->
                        <UniformGrid Columns="2" Margin="0,10,0,20">
                            <!-- Заявка 1 -->
                            <Border Background="#F8F9FA" Padding="15" CornerRadius="8" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="Ремонт Р-2026-89 от 17.02.2026" FontWeight="Bold" Margin="0,0,0,5"/>
                                    <TextBlock Text="ТС: А123ВС77 • ПАЗ Vector Next"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                                        <Ellipse Fill="Green" Width="10" Height="10" Margin="0,0,5,0"/>
                                        <TextBlock Text="В работе (Смирнов П.А.)"/>
                                    </StackPanel>
                                    <TextBlock Text="Завершить до: 20.02.2026" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="[Продолжить]" Padding="5,3"/>
                                        <Button Content="[Завершить]" Padding="5,3" Margin="10,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Заявка 2 -->
                            <Border Background="#F8F9FA" Padding="15" CornerRadius="8" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="Заявка ЗЧ-2026-45 от 18.02.2026" FontWeight="Bold" Margin="0,0,0,5"/>
                                    <TextBlock Text="ТС: Е345КХ77 • ЛИАЗ 5292"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                                        <Ellipse Fill="#3A8CD6" Width="10" Height="10" Margin="0,0,5,0"/>
                                        <TextBlock Text="Новая"/>
                                    </StackPanel>
                                    <TextBlock Text="Сумма: 12 200 руб." Margin="0,0,0,10"/>
                                    <Button Content="[Обработать]" Padding="5,3" Width="100" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>