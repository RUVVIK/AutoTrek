<Page x:Class="AutoTrek.Page11_ServiceHistory"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgLight}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource BgDark}" Grid.Row="0">
            <DockPanel>
                <TextBlock Text="История обслуживания ТС - Ремонты" Style="{StaticResource WhiteText}" Margin="20,0" VerticalAlignment="Center"/>
                <Button Content="Выход" DockPanel.Dock="Right" Background="Transparent" Foreground="White" Click="BtnExit_Click" Margin="0,0,20,0"/>
                <Button Content="Закрыть" DockPanel.Dock="Right" Background="Transparent" Foreground="White" Click="BtnClose_Click" Margin="0,0,10,0"/>
                <TextBlock Text="Механик" Style="{StaticResource WhiteText}" Margin="0,0,20,0" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Center" Width="950" Padding="20">
            <Border Style="{StaticResource Panel}">
                <StackPanel>
                    <!-- Информация о ТС -->
                    <TextBlock Text="ТС: А123ВС77 | ПАЗ Vector Next | Пробег: 187 200 км" FontWeight="Bold" Margin="0,0,0,15" FontSize="14"/>

                    <!-- Кнопки фильтров -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="Все события" Margin="0,0,5,0" Background="White"/>
                        <Button Content="Ремонты" Margin="0,0,5,0" Background="White"/>
                        <Button Content="ТО" Margin="0,0,5,0" Background="White"/>
                        <Button Content="Заправки" Margin="0,0,5,0" Background="White"/>
                        <Button Content="Пробег" Margin="0,0,5,0" Background="White"/>
                        <Button Content="Прочее" Click="BtnMore_Click" Background="{StaticResource HeaderBg}" Foreground="White" Margin="0,0,5,0"/>
                    </StackPanel>

                    <!-- Заголовок таблицы -->
                    <Border Style="{StaticResource HeaderBar}" Margin="0,0,0,15">
                        <TextBlock Text="Все ремонты и ТО" Style="{StaticResource WhiteText}" TextAlignment="Center" FontSize="16"/>
                    </Border>

                    <!-- Таблица с данными -->
                    <DataGrid Height="350" ItemsSource="{Binding History}" AutoGenerateColumns="False" 
                              BorderBrush="#D1D5DB" BorderThickness="1" 
                              GridLinesVisibility="All" 
                              HorizontalGridLinesBrush="#D1D5DB" 
                              VerticalGridLinesBrush="#D1D5DB">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата" Width="100" Binding="{Binding Date}"/>
                            <DataGridTextColumn Header="Тип" Width="80" Binding="{Binding Type}"/>
                            <DataGridTextColumn Header="Вид работ" Width="220" Binding="{Binding Work}"/>
                            <DataGridTextColumn Header="Пробег" Width="100" Binding="{Binding Mileage}"/>
                            <DataGridTextColumn Header="Механик" Width="100" Binding="{Binding Mechanic}"/>
                            <DataGridTextColumn Header="Стоимость" Width="100" Binding="{Binding Cost}"/>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Height" Value="45"/>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>

                    <!-- Кнопки навигации -->
                    <UniformGrid Columns="2" Margin="0,15">
                        <Button Content="◀ Первая" Background="White" HorizontalContentAlignment="Left"/>
                        <Button Content="Последняя ▶" Background="White" HorizontalContentAlignment="Right" Margin="10,0,0,0"/>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>