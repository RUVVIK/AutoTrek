<Page x:Class="AutoTrek.Page12_ServiceGraph"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgLight}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Background="{StaticResource BgDark}" Grid.Row="0">
            <DockPanel>
                <TextBlock Text="История обслуживания ТС - Ремонты" Style="{StaticResource WhiteText}" Margin="20,0" VerticalAlignment="Center"/>
                <Button Content="Выход" DockPanel.Dock="Right" Background="Transparent" Foreground="White" Click="BtnExit_Click" Margin="0,0,20,0"/>
                <Button Content="Закрыть" DockPanel.Dock="Right" Background="Transparent" Foreground="White" Click="BtnClose_Click" Margin="0,0,10,0"/>
                <TextBlock Text="Механик" Style="{StaticResource WhiteText}" Margin="0,0,20,0" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Контент -->
        <ScrollViewer Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Center" Width="900" Padding="20">
            <Border Style="{StaticResource Panel}">
                <StackPanel>
                    <!-- Заголовок -->
                    <TextBlock Text="График расходов на ремонты по месяцам" 
                               FontWeight="Bold" 
                               FontSize="16" 
                               TextAlignment="Center" 
                               Margin="0,0,0,20"/>

                    <!-- График -->
                    <Border Background="#F8F9FA" Height="320" Margin="0,0,0,20" CornerRadius="8" ClipToBounds="True">
                        <Grid>
                            <Canvas ClipToBounds="True">
                                <!-- Ось Y (Левая) -->
                                <Line X1="50" Y1="20" X2="50" Y2="260" Stroke="Black" StrokeThickness="1"/>
                                <TextBlock Text="Сумма, руб" Canvas.Left="5" Canvas.Top="5" FontSize="11" FontWeight="SemiBold"/>

                                <!-- Деления Y -->
                                <TextBlock Text="14000" Canvas.Left="5" Canvas.Top="25" FontSize="10"/>
                                <Line X1="45" Y1="30" X2="50" Y2="30" Stroke="Black" StrokeThickness="1"/>

                                <TextBlock Text="12000" Canvas.Left="5" Canvas.Top="65" FontSize="10"/>
                                <Line X1="45" Y1="70" X2="50" Y2="70" Stroke="Black" StrokeThickness="1"/>

                                <TextBlock Text="10000" Canvas.Left="5" Canvas.Top="105" FontSize="10"/>
                                <Line X1="45" Y1="110" X2="50" Y2="110" Stroke="Black" StrokeThickness="1"/>

                                <TextBlock Text="8000" Canvas.Left="5" Canvas.Top="145" FontSize="10"/>
                                <Line X1="45" Y1="150" X2="50" Y2="150" Stroke="Black" StrokeThickness="1"/>

                                <TextBlock Text="6000" Canvas.Left="5" Canvas.Top="185" FontSize="10"/>
                                <Line X1="45" Y1="190" X2="50" Y2="190" Stroke="Black" StrokeThickness="1"/>

                                <TextBlock Text="4000" Canvas.Left="5" Canvas.Top="225" FontSize="10"/>
                                <Line X1="45" Y1="230" X2="50" Y2="230" Stroke="Black" StrokeThickness="1"/>

                                <TextBlock Text="2000" Canvas.Left="5" Canvas.Top="250" FontSize="10"/>
                                <Line X1="45" Y1="255" X2="50" Y2="255" Stroke="Black" StrokeThickness="1"/>

                                <!-- Ось X (Нижняя) - СТРОГО ВНУТРИ -->
                                <Line X1="50" Y1="260" X2="820" Y2="260" Stroke="Black" StrokeThickness="1"/>

                                <!-- Месяцы 2025 -->
                                <TextBlock Text="Я" Canvas.Left="70" Canvas.Top="265" FontSize="10" HorizontalAlignment="Center"/>
                                <TextBlock Text="Ф" Canvas.Left="105" Canvas.Top="265" FontSize="10"/>
                                <TextBlock Text="М" Canvas.Left="140" Canvas.Top="265" FontSize="10"/>
                                <TextBlock Text="А" Canvas.Left="175" Canvas.Top="265" FontSize="10"/>
                                <TextBlock Text="М" Canvas.Left="210" Canvas.Top="265" FontSize="10"/>
                                <TextBlock Text="И" Canvas.Left="245" Canvas.Top="265" FontSize="10"/>
                                <TextBlock Text="И" Canvas.Left="280" Canvas.Top="265" FontSize="10"/>
                                <TextBlock Text="А" Canvas.Left="315" Canvas.Top="265" FontSize="10"/>
                                <TextBlock Text="С" Canvas.Left="350" Canvas.Top="265" FontSize="10"/>
                                <TextBlock Text="О" Canvas.Left="385" Canvas.Top="265" FontSize="10"/>
                                <TextBlock Text="Н" Canvas.Left="420" Canvas.Top="265" FontSize="10"/>
                                <TextBlock Text="Д" Canvas.Left="455" Canvas.Top="265" FontSize="10"/>

                                <TextBlock Text="2025" Canvas.Left="70" Canvas.Top="280" FontSize="10" FontWeight="SemiBold"/>

                                <!-- Месяцы 2026 -->
                                <TextBlock Text="Я" Canvas.Left="490" Canvas.Top="265" FontSize="10"/>
                                <TextBlock Text="Ф" Canvas.Left="525" Canvas.Top="265" FontSize="10"/>
                                <TextBlock Text="М" Canvas.Left="560" Canvas.Top="265" FontSize="10" Foreground="Gray"/>
                                <TextBlock Text="А" Canvas.Left="595" Canvas.Top="265" FontSize="10" Foreground="Gray"/>
                                <TextBlock Text="М" Canvas.Left="630" Canvas.Top="265" FontSize="10" Foreground="Gray"/>
                                <TextBlock Text="И" Canvas.Left="665" Canvas.Top="265" FontSize="10" Foreground="Gray"/>
                                <TextBlock Text="И" Canvas.Left="700" Canvas.Top="265" FontSize="10" Foreground="Gray"/>
                                <TextBlock Text="А" Canvas.Left="735" Canvas.Top="265" FontSize="10" Foreground="Gray"/>

                                <TextBlock Text="2026" Canvas.Left="490" Canvas.Top="280" FontSize="10" FontWeight="SemiBold"/>

                                <!-- 2027 (Пусто/Серый) -->
                                <TextBlock Text="2027" Canvas.Left="750" Canvas.Top="280" FontSize="10" FontWeight="SemiBold" Foreground="Gray"/>
                                <Line X1="750" Y1="260" X2="820" Y2="260" Stroke="Gray" StrokeThickness="1" StrokeDashArray="2,2"/>

                                <!-- СИНЯЯ ЛИНИЯ ГРАФИКА (Полилайн) -->
                                <!-- Координаты по твоему рисунку -->
                                <Polyline Points="70,140 105,155 140,145 175,165 210,175 245,190 280,205 315,210 350,50 385,85 420,40 455,85 490,95 525,100" 
                                          Stroke="#3A8CD6" 
                                          StrokeThickness="3"/>

                                <!-- Точка конца линии (Февраль 2026) -->
                                <Ellipse Fill="#3A8CD6" Width="8" Height="8" Canvas.Left="521" Canvas.Top="96"/>
                            </Canvas>
                        </Grid>
                    </Border>

                    <!-- Кнопки -->
                    <UniformGrid Columns="4" Margin="0,10">
                        <Button Content="Сформировать акт" Height="45" Margin="5,0" FontSize="13"/>
                        <Button Content="Добавить запись" Height="45" Margin="5,0" FontSize="13"/>
                        <Button Content="Редактировать" Height="45" Margin="5,0" FontSize="13"/>
                        <Button Content="Удалить" Height="45" Margin="5,0" FontSize="13"/>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>