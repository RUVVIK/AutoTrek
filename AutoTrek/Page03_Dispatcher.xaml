<Page x:Class="AutoTrek.Page03_Dispatcher"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgLight}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Background="{StaticResource BgDark}" Grid.Row="0">
            <DockPanel>
                <TextBlock Text="Диспетчер" Style="{StaticResource WhiteText}" Margin="20,0" VerticalAlignment="Center" FontSize="16"/>
                <Button Content="Выход" DockPanel.Dock="Right" Background="Transparent" Foreground="White" Click="BtnExit_Click" Margin="0,0,20,0" Width="80"/>
                <StackPanel Orientation="Horizontal" Margin="30,0">
                    <Button Content="Файл" Background="Transparent" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="Справочники" Background="Transparent" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="Отчёты" Background="Transparent" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="Настройки" Background="Transparent" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="Помощь" Background="Transparent" Foreground="White"/>
                </StackPanel>
            </DockPanel>
        </Border>
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel>
                <UniformGrid Columns="3" Height="120" Margin="0,0,0,20">
                    <Button Style="{StaticResource BigBtn}" Content="Путевые листы&#10;Ввод данных с путевых листов" Click="Nav_Click" Tag="Page04_TripSheet"/>
                    <Button Style="{StaticResource BigBtn}" Content="Заправки&#10;Регистрация заправок" Click="Nav_Click" Tag="Page05_Fueling"/>
                    <Button Style="{StaticResource BigBtn}" Content="Календарь ТО&#10;Просмотр ТО" Click="Nav_Click" Tag="Page06_Maintenance"/>
                </UniformGrid>
                <Border Style="{StaticResource Panel}">
                    <StackPanel>
                        <Border Style="{StaticResource HeaderBar}" CornerRadius="8">
                            <TextBlock Text="Информационная панель" Style="{StaticResource WhiteText}" TextAlignment="Center"/>
                        </Border>
                        <Grid Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Сегодня: 28.10.2026" FontSize="14" VerticalAlignment="Center"/>
                            <Button Content="Обновить" Grid.Column="1" Margin="5"/>
                            <Button Content="Показать все" Grid.Column="2" Margin="5"/>
                            <Button Content="Экспорт в Excel" Grid.Column="3" Margin="5"/>
                        </Grid>
                        <TextBlock Text="История записей:" FontWeight="SemiBold" Margin="0,15,0,5"/>
                        <DataGrid Height="200" ItemsSource="{Binding Records}" AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="№" Width="50" Binding="{Binding Id}"/>
                                <DataGridTextColumn Header="Дата" Width="100" Binding="{Binding Date}"/>
                                <DataGridTextColumn Header="Гос. номер" Width="130" Binding="{Binding Plate}"/>
                                <DataGridTextColumn Header="Тип" Width="100" Binding="{Binding Type}"/>
                                <DataGridTextColumn Header="Значение" Width="100" Binding="{Binding Value}"/>
                                <DataGridTextColumn Header="Статус" Width="100" Binding="{Binding Status}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>