<Page x:Class="AutoTrek.Page19_PlanFact"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgLight}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Background="{StaticResource BgDark}" Grid.Row="0">
            <DockPanel>
                <TextBlock Text="Анализ план/факт по ТС" Style="{StaticResource WhiteText}" Margin="20,0" VerticalAlignment="Center"/>
                <Button Content="Выход" DockPanel.Dock="Right" Background="Transparent" Foreground="White" Click="BtnExit_Click" Margin="0,0,20,0"/>
                <Button Content="Закрыть" DockPanel.Dock="Right" Background="Transparent" Foreground="White" Click="BtnClose_Click" Margin="0,0,10,0"/>
                <TextBlock Text="Руководитель" Style="{StaticResource WhiteText}" Margin="0,0,20,0" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Контент -->
        <ScrollViewer Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Center" Width="900" Padding="20">
            <Border Style="{StaticResource Panel}">
                <StackPanel>
                    <!-- Заголовок -->
                    <Border Style="{StaticResource HeaderBar}">
                        <TextBlock Text="Сравнительный анализ план/факт по ТС" Style="{StaticResource WhiteText}" TextAlignment="Center" FontSize="15"/>
                    </Border>

                    <!-- Параметры -->
                    <Border Style="{StaticResource HeaderBar}" Background="#E8F0FE">
                        <StackPanel>
                            <TextBlock Text="Параметры" FontWeight="Bold" Foreground="#2C527A" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Label Content="Транспортное средство:" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" Margin="0,5,10,5" Height="30"/>
                                <Label Grid.Column="2" Content="Период анализа:" VerticalAlignment="Center"/>
                                <Grid Grid.Column="3" Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="01.01.2026" Height="30"/>
                                    <TextBlock Grid.Column="1" Text="по:" VerticalAlignment="Center" Margin="10,0"/>
                                    <TextBox Grid.Column="2" Text="28.02.2026" Height="30"/>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Таблица анализа по статьям -->
                    <Border Style="{StaticResource HeaderBar}" Margin="0,15,0,0">
                        <TextBlock Text="Анализ по статьям затрат" Style="{StaticResource WhiteText}" TextAlignment="Center"/>
                    </Border>

                    <DataGrid Height="132" ItemsSource="{Binding PlanFactTable}" AutoGenerateColumns="False" IsReadOnly="True"
                              BorderBrush="#D1D5DB" BorderThickness="1"
                              GridLinesVisibility="All" HorizontalGridLinesBrush="#D1D5DB" VerticalGridLinesBrush="#D1D5DB"
                              FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Статья затрат" Width="150" Binding="{Binding Article}"/>
                            <DataGridTextColumn Header="План (руб)" Width="100" Binding="{Binding Plan}"/>
                            <DataGridTextColumn Header="Факт (руб)" Width="100" Binding="{Binding Fact}"/>
                            <DataGridTextColumn Header="Откл. (руб)" Width="100" Binding="{Binding Deviation}"/>
                            <DataGridTextColumn Header="% вып." Width="70" Binding="{Binding Percent}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Визуализация отклонений -->
                    <Border Style="{StaticResource HeaderBar}" Margin="0,15,0,0">
                        <TextBlock Text="Визуализация отклонений" Style="{StaticResource WhiteText}" TextAlignment="Center"/>
                    </Border>

                    <Border Background="#F8F9FA" Padding="15" CornerRadius="8" Margin="0,10">
                        <Canvas Height="200">
                            <!-- Ось X с подписями -->
                            <Line X1="80" Y1="180" X2="500" Y2="180" Stroke="Black" StrokeThickness="1" HorizontalAlignment="Center" Canvas.Top="40" VerticalAlignment="Top" Width="560"/>
                            <TextBlock Text="0%" Canvas.Left="80" Canvas.Top="220" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                            <TextBlock Text="20%" Canvas.Left="120" Canvas.Top="220" FontSize="9" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <TextBlock Text="40%" Canvas.Left="160" Canvas.Top="220" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                            <TextBlock Text="60%" Canvas.Left="200" Canvas.Top="220" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                            <TextBlock Text="80%" Canvas.Left="240" Canvas.Top="220" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                            <TextBlock Text="100%" Canvas.Left="280" Canvas.Top="220" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                            <TextBlock Text="120%" Canvas.Left="320" Canvas.Top="220" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Top"/>

                            <!-- ГСМ 108% -->
                            <TextBlock Text="ГСМ" Canvas.Left="10" Canvas.Top="15" FontSize="11"/>
                            <Line X1="80" Y1="25" X2="500" Y2="25" Stroke="Black" StrokeThickness="1"/>
                            <Rectangle Fill="#1E5B9B" Canvas.Left="80" Canvas.Top="30" Width="216" Height="14"/>
                            <TextBlock Text="108%" Canvas.Left="300" Canvas.Top="28" FontSize="10" FontWeight="Bold"/>
                            <TextBlock Text="+" Canvas.Left="327" Canvas.Top="27" FontSize="10" Foreground="Red" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                            <!-- Ремонты 119% -->
                            <TextBlock Text="Ремонты" Canvas.Left="10" Canvas.Top="70" FontSize="11"/>
                            <Line X1="80" Y1="80" X2="500" Y2="80" Stroke="Black" StrokeThickness="1"/>
                            <Rectangle Fill="#1E5B9B" Canvas.Left="80" Canvas.Top="85" Width="238" Height="14"/>
                            <TextBlock Text="119%" Canvas.Left="322" Canvas.Top="83" FontSize="10" FontWeight="Bold"/>
                            <TextBlock Text="+" Canvas.Left="349" Canvas.Top="82" FontSize="10" Foreground="Red" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                            <!-- Мойка 83% -->
                            <TextBlock Text="Мойка" Canvas.Left="10" Canvas.Top="125" FontSize="11"/>
                            <Line X1="80" Y1="135" X2="500" Y2="135" Stroke="Black" StrokeThickness="1"/>
                            <Rectangle Fill="#1E5B9B" Canvas.Left="80" Canvas.Top="140" Width="166" Height="14"/>
                            <TextBlock Text="83%" Canvas.Left="250" Canvas.Top="138" FontSize="10" FontWeight="Bold"/>
                            <TextBlock Text="-" Canvas.Left="275" Canvas.Top="138" FontSize="10" Foreground="Green"/>

                            <!-- Страховка 100% -->
                            <TextBlock Text="Страховка" Canvas.Left="10" Canvas.Top="180" FontSize="11"/>
                            <Line X1="80" Y1="190" X2="500" Y2="190" Stroke="Black" StrokeThickness="1" HorizontalAlignment="Center" Canvas.Top="-9" VerticalAlignment="Top"/>
                            <Rectangle Fill="#1E5B9B" Canvas.Left="80" Canvas.Top="186" Width="200" Height="14" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                            <TextBlock Text="100%" Canvas.Left="285" Canvas.Top="187" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                        </Canvas>
                    </Border>

                    <!-- Детализация перерасхода -->
                    <Border Style="{StaticResource HeaderBar}" Margin="0,15,0,0">
                        <TextBlock Text="Детализация перерасхода" Style="{StaticResource WhiteText}" TextAlignment="Center"/>
                    </Border>

                    <Border Background="#F8F9FA" Padding="15" CornerRadius="8" Margin="0,10">
                        <StackPanel>
                            <TextBlock Text="Основные причины превышения бюджета:" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBlock Text="• Внеплановый ремонт тормозной системы (15.02.2026) - 6 950 руб." Margin="0,3"/>
                            <TextBlock Text="• Рост цен на топливо (+2.5 руб/л с 01.02) - +4 500 руб." Margin="0,3"/>
                            <TextBlock Text="• Дополнительный пробег по сравнению с планом (+350 км)" Margin="0,3"/>

                            <TextBlock Text="Рекомендации:" FontWeight="Bold" Margin="0,15,0,8"/>
                            <TextBlock Text="• Пересмотреть нормативы расхода топлива" Margin="0,3"/>
                            <TextBlock Text="• Ужесточить контроль за состоянием тормозной системы" Margin="0,3"/>
                        </StackPanel>
                    </Border>

                    <!-- Кнопки -->
                    <UniformGrid Columns="4" Margin="0,15">
                        <Button Content="Утвердить бюджет" Height="40" Background="{StaticResource HeaderBg}" Foreground="White"/>
                        <Button Content="Скорректировать план" Height="40" Background="#E8F0FE"/>
                        <Button Content="Экспорт" Height="40" Background="#E8F0FE"/>
                        <Button Content="Печать" Height="40" Background="#E8F0FE"/>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>