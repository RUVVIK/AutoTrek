<Page x:Class="AutoTrek.Page16_Analytics"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgLight}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Background="{StaticResource BgDark}" Grid.Row="0">
            <DockPanel>
                <TextBlock Text="Аналитика по ТС" Style="{StaticResource WhiteText}" Margin="20,0" VerticalAlignment="Center"/>
                <Button Content="Выход" DockPanel.Dock="Right" Background="Transparent" Foreground="White" Click="BtnExit_Click" Margin="0,0,20,0"/>
                <Button Content="Закрыть" DockPanel.Dock="Right" Background="Transparent" Foreground="White" Click="BtnClose_Click" Margin="0,0,10,0"/>
                <TextBlock Text="Бухгалтер" Style="{StaticResource WhiteText}" Margin="0,0,20,0" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Контент -->
        <ScrollViewer Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Center" Width="900" Padding="20">
            <Border Style="{StaticResource Panel}">
                <StackPanel>
                    <!-- Кнопки навигации -->
                    <UniformGrid Columns="5" Margin="0,0,0,15">
                        <Button Content="← Назад" Click="BtnBack_Click"/>
                        <Button Content="Аналитика по ТС"/>
                        <Button Content="Обновить" Click="BtnRefresh_Click"/>
                        <Button Content="Экспорт"/>
                        <Button Content="Печать"/>
                    </UniformGrid>

                    <!-- Выбор транспортного средства -->
                    <Border Style="{StaticResource HeaderBar}">
                        <TextBlock Text="Выбор транспортного средства" Style="{StaticResource WhiteText}" TextAlignment="Center" FontSize="16"/>
                    </Border>

                    <Grid Margin="0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Content="Транспортное средство:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" Margin="0,5,0,10" Height="35" SelectedIndex="0">
                            <ComboBoxItem Content="А123ВС77 - ПАЗ Vector Next (Автобус средний, дизель)"/>
                            <ComboBoxItem Content="В234СТ77 - ГАЗель NEXT А65R33"/>
                            <ComboBoxItem Content="Е345КХ77 - ЛИАЗ 5292"/>
                        </ComboBox>

                        <Label Grid.Row="1" Content="Период анализа:" VerticalAlignment="Center"/>
                        <Grid Grid.Row="1" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="с" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox Grid.Column="1" Text="01.01.2025" Height="30" Margin="0,5,10,5"/>
                            <TextBlock Grid.Column="2" Text="по" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox Grid.Column="3" Text="18.02.2026" Height="30" Margin="0,5,10,5"/>
                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="[Применить]" Margin="0,0,10,0" Click="BtnApply_Click"/>
                                <Button Content="[Сравнить с парком]" Click="BtnCompare_Click"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- Два блока рядом -->
                    <UniformGrid Columns="2" Margin="0,15">
                        <!-- Основные показатели -->
                        <Border Background="#F8F9FA" Padding="15" CornerRadius="8" Margin="0,0,5,0">
                            <StackPanel>
                                <Border Style="{StaticResource HeaderBar}" Margin="0,0,0,15">
                                    <TextBlock Text="Основные показатели" Style="{StaticResource WhiteText}" TextAlignment="Center"/>
                                </Border>

                                <StackPanel Margin="0,10">
                                    <TextBlock Text="Общий пробег за период:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBlock Text="45 200 км" Margin="0,0,0,15" FontSize="14"/>

                                    <TextBlock Text="Общие затраты:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBlock Text="294 500 руб" Margin="0,0,0,15" FontSize="14"/>

                                    <TextBlock Text="Средняя стоимость 1 км:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBlock Text="6.52 руб/км" Margin="0,0,0,15" FontSize="14"/>

                                    <TextBlock Text="Экономия/перерасход:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBlock Text="+24 500 руб (+9.1%)" Foreground="Red" Margin="0,0,0,5"/>
                                    <TextBlock Text="(перерасход)" FontStyle="Italic" Foreground="Gray"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Динамика затрат по месяцам -->
                        <Border Background="#F8F9FA" Padding="15" CornerRadius="8" Margin="5,0,0,0">
                            <StackPanel>
                                <Border Style="{StaticResource HeaderBar}" Margin="0,0,0,15">
                                    <TextBlock Text="Динамика затрат по месяцам" Style="{StaticResource WhiteText}" TextAlignment="Center"/>
                                </Border>
                                <Canvas Height="220" Background="White" Margin="0,10">
                                    <!-- Ось Y -->
                                    <Line X1="50" Y1="10" X2="50" Y2="190" Stroke="Black" StrokeThickness="1"/>
                                    <TextBlock Text="тыс.руб" Canvas.Left="32" Canvas.Top="-15" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Top"/>

                                    <!-- Деления оси Y -->
                                    <TextBlock Text="120" Canvas.Left="15" Canvas.Top="10" FontSize="10"/>
                                    <Line X1="45" Y1="15" X2="50" Y2="15" Stroke="Black" StrokeThickness="1"/>

                                    <TextBlock Text="100" Canvas.Left="15" Canvas.Top="40" FontSize="10"/>
                                    <Line X1="45" Y1="45" X2="50" Y2="45" Stroke="Black" StrokeThickness="1"/>

                                    <TextBlock Text="80" Canvas.Left="15" Canvas.Top="70" FontSize="10"/>
                                    <Line X1="45" Y1="75" X2="50" Y2="75" Stroke="Black" StrokeThickness="1"/>

                                    <TextBlock Text="60" Canvas.Left="15" Canvas.Top="100" FontSize="10"/>
                                    <Line X1="45" Y1="105" X2="50" Y2="105" Stroke="Black" StrokeThickness="1"/>

                                    <TextBlock Text="40" Canvas.Left="15" Canvas.Top="130" FontSize="10"/>
                                    <Line X1="45" Y1="135" X2="50" Y2="135" Stroke="Black" StrokeThickness="1"/>

                                    <TextBlock Text="20" Canvas.Left="15" Canvas.Top="160" FontSize="10"/>
                                    <Line X1="45" Y1="165" X2="50" Y2="165" Stroke="Black" StrokeThickness="1"/>

                                    <TextBlock Text="0" Canvas.Left="20" Canvas.Top="185" FontSize="10"/>
                                    <Line X1="45" Y1="190" X2="50" Y2="190" Stroke="Black" StrokeThickness="1"/>

                                    <!-- Ось X (укорочена до МАР) -->
                                    <Line X1="50" Y1="190" X2="220" Y2="190" Stroke="Black" StrokeThickness="1"/>

                                    <!-- Подписи месяцев -->
                                    <TextBlock Text="ЯНВ" Canvas.Left="75" Canvas.Top="195" FontSize="10"/>
                                    <TextBlock Text="ФЕВ" Canvas.Left="125" Canvas.Top="195" FontSize="10"/>
                                    <TextBlock Text="МАР" Canvas.Left="175" Canvas.Top="195" FontSize="10"/>

                                    <!-- Точки Факта (по одной на месяц) -->
                                    <Ellipse Fill="#1E5B9B" Width="10" Height="10" Canvas.Left="80" Canvas.Top="155"/>
                                    <Ellipse Fill="#1E5B9B" Width="10" Height="10" Canvas.Left="130" Canvas.Top="65"/>
                                    <Ellipse Fill="#1E5B9B" Width="10" Height="10" Canvas.Left="180" Canvas.Top="95"/>

                                    <!-- Линия План (пунктир на уровне ~40) -->
                                    <Line X1="60" Y1="150" X2="210" Y2="150" Stroke="Black" StrokeThickness="1" StrokeDashArray="4,2"/>

                                    <!-- Легенда -->
                                    <StackPanel Orientation="Horizontal" Canvas.Left="92" Canvas.Top="220" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Line X1="0" Y1="4" X2="20" Y2="4" Stroke="Gray" StrokeThickness="1" StrokeDashArray="4,4" Margin="0,0,5,0" Height="6"/>
                                        <TextBlock Text="план" FontSize="10"/>
                                        <Ellipse Fill="#1E5B9B" Width="8" Height="8" Margin="15,0,5,0"/>
                                        <TextBlock Text="факт" FontSize="10"/>
                                    </StackPanel>
                                </Canvas>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Кнопка аналитики -->
                    <Button Content="Аналитика по ТС" Click="BtnDetails_Click" Width="250" Height="45" Margin="0,15" 
                            Background="{StaticResource HeaderBg}" Foreground="White" FontSize="15"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>