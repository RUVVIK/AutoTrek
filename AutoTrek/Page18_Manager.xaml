<Page x:Class="AutoTrek.Page18_Manager"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgLight}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Background="{StaticResource BgDark}" Grid.Row="0">
            <DockPanel>
                <TextBlock Text="Руководитель" Style="{StaticResource WhiteText}" Margin="20,0" VerticalAlignment="Center" FontSize="16"/>
                <Button Content="Выход" DockPanel.Dock="Right" Background="Transparent" Foreground="White" Click="BtnExit_Click" Margin="0,0,20,0" Width="80"/>
                <StackPanel Orientation="Horizontal" Margin="30,0">
                    <Button Content="Дашборд" Background="Transparent" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="Аналитика" Background="Transparent" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="Отчёты" Background="Transparent" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="Планирование" Background="Transparent" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="Настройки" Background="Transparent" Foreground="White"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Контент -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel>
                <!-- Заголовок дашборда -->
                <Border Style="{StaticResource HeaderBar}">
                    <TextBlock Text="Дашборд руководителя | 18 февраля 2026" Style="{StaticResource WhiteText}" TextAlignment="Center" FontSize="15"/>
                </Border>

                <!-- Карточки KPI -->
                <UniformGrid Columns="3" Height="110" Margin="0,15,0,20">
                    <Border Style="{StaticResource Panel}" Margin="0,5,0,0" Width="230">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="1 245 780 руб" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Общие затраты за февраль" TextAlignment="Center" Margin="0,5,0,0"/>
                            <TextBlock Text="▼ 3.2% к плану" TextAlignment="Center" Foreground="Green" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Panel}" Margin="0,5,0,0" Width="237">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="42.5 руб" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Стоимость за 1 км" TextAlignment="Center"/>
                            <TextBlock Text="средняя по парку" TextAlignment="Center"/>
                            <TextBlock Text="▲ 2.1% к плану" TextAlignment="Center" Foreground="Red" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Panel}" Margin="0,5,0,0" Width="231">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="+5.2%" FontSize="22" FontWeight="Bold" Foreground="Red" HorizontalAlignment="Center"/>
                            <TextBlock Text="Отклонение по расходу ГСМ" TextAlignment="Center" Margin="0,5,0,0"/>
                            <TextBlock Text="(перерасход)" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Динамика затрат (план/факт) -->
                <Border Style="{StaticResource Panel}">
                    <StackPanel>
                        <Border Style="{StaticResource HeaderBar}">
                            <TextBlock Text="Динамика затрат по месяцам (план/факт)" Style="{StaticResource WhiteText}" TextAlignment="Center"/>
                        </Border>

                        <Canvas Height="280" Background="#F8F9FA" Margin="0,15" ClipToBounds="True">
                            <!-- Ось Y -->
                            <Line X1="60" Y1="20" X2="60" Y2="240" Stroke="Black" StrokeThickness="1"/>
                            <TextBlock Text="тыс. руб" Canvas.Left="31" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                            <TextBlock Text="1400" Canvas.Left="15" Canvas.Top="17" FontSize="10"/>
                            <Line X1="55" Y1="20" X2="60" Y2="20" Stroke="Black" StrokeThickness="1"/>

                            <TextBlock Text="1300" Canvas.Left="15" Canvas.Top="51" FontSize="10"/>
                            <Line X1="55" Y1="54" X2="60" Y2="54" Stroke="Black" StrokeThickness="1"/>

                            <TextBlock Text="1200" Canvas.Left="15" Canvas.Top="85" FontSize="10"/>
                            <Line X1="55" Y1="88" X2="60" Y2="88" Stroke="Black" StrokeThickness="1"/>

                            <TextBlock Text="1100" Canvas.Left="15" Canvas.Top="119" FontSize="10"/>
                            <Line X1="55" Y1="122" X2="60" Y2="122" Stroke="Black" StrokeThickness="1"/>

                            <TextBlock Text="1000" Canvas.Left="15" Canvas.Top="153" FontSize="10"/>
                            <Line X1="55" Y1="156" X2="60" Y2="156" Stroke="Black" StrokeThickness="1"/>

                            <TextBlock Text="900" Canvas.Left="22" Canvas.Top="187" FontSize="10"/>
                            <Line X1="55" Y1="190" X2="60" Y2="190" Stroke="Black" StrokeThickness="1"/>

                            <TextBlock Text="800" Canvas.Left="22" Canvas.Top="221" FontSize="10"/>
                            <Line X1="55" Y1="224" X2="60" Y2="224" Stroke="Black" StrokeThickness="1"/>

                            <!-- Ось X -->
                            <Line X1="60" Y1="240" X2="520" Y2="240" Stroke="Black" StrokeThickness="1"/>
                            <TextBlock Text="Сен" Canvas.Left="80" Canvas.Top="245" FontSize="10"/>
                            <TextBlock Text="Окт" Canvas.Left="143" Canvas.Top="245" FontSize="10"/>
                            <TextBlock Text="Ноя" Canvas.Left="206" Canvas.Top="245" FontSize="10"/>
                            <TextBlock Text="Дек" Canvas.Left="269" Canvas.Top="245" FontSize="10"/>
                            <TextBlock Text="Янв" Canvas.Left="332" Canvas.Top="245" FontSize="10"/>
                            <TextBlock Text="Фев" Canvas.Left="395" Canvas.Top="245" FontSize="10"/>
                            <TextBlock Text="Мар" Canvas.Left="458" Canvas.Top="245" FontSize="10"/>

                            <!-- Линия Плана (пунктир, уровень ~800) -->
                            <Line X1="70" Y1="220" X2="480" Y2="180" Stroke="Gray" StrokeThickness="1.5" StrokeDashArray="5,3"/>

                            <!-- Линия Факта — ломаная между точками (по скрину Figma) -->
                            <!-- Сен 800 → Окт 900 → Ноя 1200 → Янв 1000 → Фев 1200 → Мар 1400 -->
                            <Line X1="91"  Y1="224" X2="154" Y2="190" Stroke="#1E5B9B" StrokeThickness="2"/>
                            <Line X1="154" Y1="190" X2="217" Y2="88"  Stroke="#1E5B9B" StrokeThickness="2"/>
                            <Line X1="217" Y1="88"  X2="343" Y2="156" Stroke="#1E5B9B" StrokeThickness="2"/>
                            <Line X1="343" Y1="156" X2="406" Y2="88"  Stroke="#1E5B9B" StrokeThickness="2"/>
                            <Line X1="406" Y1="88"  X2="469" Y2="20"  Stroke="#1E5B9B" StrokeThickness="2"/>

                            <!-- Точки факта (большие, как на Figma) -->
                            <Ellipse Width="14" Height="14" Canvas.Left="84"  Canvas.Top="217" Fill="#1E5B9B"/>
                            <Ellipse Width="14" Height="14" Canvas.Left="147" Canvas.Top="183" Fill="#1E5B9B"/>
                            <Ellipse Width="14" Height="14" Canvas.Left="210" Canvas.Top="81"  Fill="#1E5B9B"/>
                            <Ellipse Width="14" Height="14" Canvas.Left="336" Canvas.Top="149" Fill="#1E5B9B"/>
                            <Ellipse Width="14" Height="14" Canvas.Left="399" Canvas.Top="81"  Fill="#1E5B9B"/>
                            <Ellipse Width="14" Height="14" Canvas.Left="462" Canvas.Top="13"  Fill="#1E5B9B"/>

                            <!-- Легенда -->
                            <StackPanel Orientation="Horizontal" Canvas.Left="240" Canvas.Top="262" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Line X1="0" Y1="4" X2="20" Y2="4" Stroke="Gray" StrokeThickness="1" StrokeDashArray="4,4" Margin="0,0,5,0" Height="5"/>
                                <TextBlock Text="план" FontSize="11"/>
                                <Ellipse Width="10" Height="10" Canvas.Left="0" Canvas.Top="0" Fill="#1E5B9B" Margin="15,0,5,0"/>
                                <TextBlock Text="факт" FontSize="11"/>
                            </StackPanel>
                        </Canvas>
                    </StackPanel>
                </Border>

                <!-- Таблица ТОП-5 -->
                <Border Style="{StaticResource HeaderBar}" Margin="0,15,0,0">
                    <TextBlock Text="ТОП-5 самых затратных транспортных средств" Style="{StaticResource WhiteText}" TextAlignment="Center"/>
                </Border>

                <DataGrid Height="136" ItemsSource="{Binding Top5Table}" AutoGenerateColumns="False" IsReadOnly="True"
                          BorderBrush="#D1D5DB" BorderThickness="1"
                          GridLinesVisibility="All" HorizontalGridLinesBrush="#D1D5DB" VerticalGridLinesBrush="#D1D5DB"
                          FontSize="12" Margin="0,10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№" Width="50" Binding="{Binding Number}"/>
                        <DataGridTextColumn Header="Госномер" Width="100" Binding="{Binding Plate}"/>
                        <DataGridTextColumn Header="Модель" Width="150" Binding="{Binding Model}"/>
                        <DataGridTextColumn Header="Затраты, руб" Width="110" Binding="{Binding Cost}"/>
                        <DataGridTextColumn Header="на 1 км" Width="80" Binding="{Binding PerKm}"/>
                        <DataGridTextColumn Header="Откл." Width="70" Binding="{Binding Deviation}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Три кнопки -->
                <UniformGrid Columns="3" Margin="0,10">
                    <Button Content="Детальный анализ" Height="40" Background="#E8F0FE" Click="BtnDetails_Click"/>
                    <Button Content="График по ТС" Height="40" Background="#E8F0FE" Margin="5,0"/>
                    <Button Content="Сравнить" Height="40" Background="#E8F0FE"/>
                </UniformGrid>

                <!-- Два блока внизу -->
                <UniformGrid Columns="2" Margin="0,15">
                    <!-- Структура затрат -->
                    <Border Style="{StaticResource Panel}" Margin="0,0,5,0" Height="235">
                        <StackPanel>
                            <Border Style="{StaticResource HeaderBar}">
                                <TextBlock Text="Структура затрат" Style="{StaticResource WhiteText}" TextAlignment="Center"/>
                            </Border>
                            <Canvas Height="159" Margin="0,10">
                                <!-- ГСМ 52% -->
                                <Rectangle Fill="#1E3A5F" Canvas.Left="75" Canvas.Top="20" Width="130" Height="18" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <TextBlock Text="ГСМ" Canvas.Left="215" Canvas.Top="23" FontSize="11" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <TextBlock Text="52%" Canvas.Left="255" Canvas.Top="23" FontSize="11" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                                <!-- Ремонты 34% -->
                                <Rectangle Fill="#2C5A8A" Canvas.Left="97" Canvas.Top="60" Width="85" Height="18" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <TextBlock Text="Ремонты" Canvas.Left="190" Canvas.Top="63" FontSize="11" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <TextBlock Text="34%" Canvas.Left="255" Canvas.Top="63" FontSize="11" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                                <!-- Прочее 14% -->
                                <Rectangle Fill="#3A7AB5" Canvas.Left="122" Canvas.Top="100" Width="35" Height="18" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <TextBlock Text="Прочее" Canvas.Left="165" Canvas.Top="103" FontSize="11" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <TextBlock Text="14%" Canvas.Left="255" Canvas.Top="103" FontSize="11" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                                <!-- Рамка -->
                            </Canvas>
                        </StackPanel>
                    </Border>

                    <!-- Предстоящие ТО -->
                    <Border Style="{StaticResource Panel}" Margin="5,0,0,0" Height="236">
                        <StackPanel>
                            <Border Style="{StaticResource HeaderBar}">
                                <TextBlock Text="Предстоящие ТО (ближайшие 7 дней)" Style="{StaticResource WhiteText}" TextAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="0,10">
                                <TextBlock Text="19.02 - А123ВС77 (ТО-1)" Margin="0,5" FontSize="12"/>
                                <TextBlock Text="20.02 - В234СТ77 (замена масла)" Margin="0,5" FontSize="12"/>
                                <TextBlock Text="21.02 - М567НВ77 (ТО-2)" Margin="0,5" FontSize="12"/>
                                <TextBlock Text="23.02 - Е345КХ77 (диагностика)" Margin="0,5" FontSize="12"/>
                            </StackPanel>
                            <UniformGrid Columns="2" Margin="0,10">
                                <Button Content="Календарь ТО" Height="35"/>
                                <Button Content="Напомнить" Height="35" Margin="5,0,0,0"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Кнопки внизу -->
                <UniformGrid Columns="4" Margin="0,10">
                    <Button Content="Детальные отчёты" Height="40" Background="#E8F0FE"/>
                    <Button Content="Утвердить бюджет" Height="40" Background="{StaticResource HeaderBg}" Foreground="White" Click="BtnApprove_Click"/>
                    <Button Content="Печать" Height="40" Background="#E8F0FE"/>
                    <Button Content="Экспорт" Height="40" Background="#E8F0FE"/>
                </UniformGrid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>