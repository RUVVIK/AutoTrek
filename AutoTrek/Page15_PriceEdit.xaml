<Page x:Class="AutoTrek.Page15_PriceEdit"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgLight}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Background="{StaticResource BgDark}" Grid.Row="0">
            <DockPanel>
                <TextBlock Text="Редактирование цен" Style="{StaticResource WhiteText}" Margin="20,0" VerticalAlignment="Center"/>
                <Button Content="Выход" DockPanel.Dock="Right" Background="Transparent" Foreground="White" Click="BtnExit_Click" Margin="0,0,20,0"/>
                <Button Content="Закрыть" DockPanel.Dock="Right" Background="Transparent" Foreground="White" Click="BtnClose_Click" Margin="0,0,10,0"/>
                <TextBlock Text="Бухгалтер" Style="{StaticResource WhiteText}" Margin="0,0,20,0" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Основной контент -->
        <ScrollViewer Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Center" Width="850" Padding="20">
            <Border Style="{StaticResource Panel}">
                <StackPanel>
                    <!-- Заголовок управления -->
                    <Border Style="{StaticResource HeaderBar}">
                        <TextBlock Text="Управления ценами и тарифами" Style="{StaticResource WhiteText}" TextAlignment="Center"/>
                    </Border>

                    <!-- Вкладки -->
                    <UniformGrid Columns="4" Margin="0,0,0,10">
                        <Button Content="Топливо" Background="{StaticResource HeaderBg}" Foreground="White"/>
                        <Button Content="Запчасти" Margin="5,0,0,0"/>
                        <Button Content="Услуги" Margin="5,0,0,0"/>
                        <Button Content="Работы" Margin="5,0,0,0"/>
                    </UniformGrid>

                    <!-- Заголовок таблицы -->
                    <Border Style="{StaticResource HeaderBar}" Margin="0,0,0,10">
                        <TextBlock Text="Цены на топливо" Style="{StaticResource WhiteText}" TextAlignment="Center"/>
                    </Border>

                    <!-- Таблица с данными -->
                    <DataGrid Height="200" ItemsSource="{Binding FuelPrices}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Тип топлива" Width="100" Binding="{Binding Type}"/>
                            <DataGridTextColumn Header="Поставщик" Width="100" Binding="{Binding Supplier}"/>
                            <DataGridTextColumn Header="Цена, руб/л" Width="100" Binding="{Binding Price}"/>
                            <DataGridTextColumn Header="Дата изм." Width="100" Binding="{Binding Date}"/>
                            <DataGridTextColumn Header="Статус" Width="100" Binding="{Binding Status}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Кнопки действий -->
                    <UniformGrid Columns="4" Margin="0,10,0,0">
                        <Button Content="Добавить цену"/>
                        <Button Content="Редактировать"/>
                        <Button Content="Удалить"/>
                        <Button Content="Архивировать"/>
                    </UniformGrid>

                    <!-- Форма добавления -->
                    <Border Style="{StaticResource HeaderBar}" Margin="0,15">
                        <TextBlock Text="Добавление новой цены" Style="{StaticResource WhiteText}" TextAlignment="Center"/>
                    </Border>

                    <Grid Margin="0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Content="Тип топлива:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"/>

                        <Label Grid.Row="1" Content="Поставщик:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1"/>

                        <Label Grid.Row="2" Content="Цена за литр:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1"/>

                        <Label Grid.Row="3" Content="Дата ввода:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="3" Grid.Column="1"/>
                    </Grid>

                    <Button Content="Добавить" Width="200" Margin="0,10"/>

                    <!-- Средние цены -->
                    <TextBlock Text="Средние цены за период:" FontWeight="Bold" Margin="0,15,0,5"/>
                    <TextBlock Text="Дизель: 62.45 руб/л" Margin="0,2"/>
                    <TextBlock Text="АИ-92: 54.10 руб/л" Margin="0,2"/>
                    <TextBlock Text="АИ-95: 58.70 руб/л" Margin="0,2"/>

                    <!-- Кнопка сохранения -->
                    <Button Content="Сохранить изменения" Height="45" Margin="0,15" Background="{StaticResource HeaderBg}" Foreground="White" FontSize="15"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>