<Page x:Class="AutoTrek.Page13_Accountant"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgLight}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Background="{StaticResource BgDark}" Grid.Row="0">
            <DockPanel>
                <TextBlock Text="Бухгалтер" Style="{StaticResource WhiteText}" Margin="20,0" VerticalAlignment="Center" FontSize="16"/>
                <Button Content="Выход" DockPanel.Dock="Right" Background="Transparent" Foreground="White" Click="BtnExit_Click" Margin="0,0,20,0" Width="80"/>
                <StackPanel Orientation="Horizontal" Margin="30,0">
                    <Button Content="Файл" Background="Transparent" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="Справочники" Background="Transparent" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="Отчёты" Background="Transparent" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="Документы" Background="Transparent" Foreground="White" Margin="0,0,10,0"/>
                    <Button Content="Периоды" Background="Transparent" Foreground="White"/>
                </StackPanel>
            </DockPanel>
        </Border>
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel>
                <UniformGrid Columns="3" Height="120" Margin="0,0,0,20">
                    <Button Style="{StaticResource BigBtn}" Content="Ввод цен&#10;Топливо, запчасти, услуги" Click="Nav_Click" Tag="Page15_PriceEdit"/>
                    <Button Style="{StaticResource BigBtn}" Content="Отчёты по затратам&#10;Формирование ведомостей" Click="Nav_Click" Tag="Page14_CostReport"/>
                    <Button Style="{StaticResource BigBtn}" Content="Аналитика по ТС&#10;Детальный анализ расходов" Click="Nav_Click" Tag="Page16_Analytics"/>
                </UniformGrid>
                <Border Style="{StaticResource Panel}">
                    <StackPanel>
                        <Border Style="{StaticResource HeaderBar}" CornerRadius="8">
                            <TextBlock Text="Оперативная информация за текущий месяц" Style="{StaticResource WhiteText}" TextAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Сегодня: 28.03.2026" Margin="0,10"/>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Label Content="Затраты на ГСМ:"/>
                            <TextBox Grid.Column="1"/>
                            <Label Grid.Row="1" Content="Затраты на ремонты:"/>
                            <TextBox Grid.Row="1" Grid.Column="1"/>
                            <Label Grid.Row="2" Content="Прочие затраты:"/>
                            <TextBox Grid.Row="2" Grid.Column="1"/>
                            <Label Grid.Row="3" Content="ИТОГО:" FontWeight="Bold"/>
                            <TextBox Grid.Row="3" Grid.Column="1"/>
                        </Grid>
                        <UniformGrid Columns="2" Margin="0,15">
                            <Button Content="Посмотреть структуру"/>
                            <Button Content="Сравнить с прошлым месяцем" Margin="10,0,0,0"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>