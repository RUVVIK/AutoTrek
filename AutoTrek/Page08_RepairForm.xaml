<Page x:Class="AutoTrek.Page08_RepairForm"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgLight}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Background="{StaticResource BgDark}" Grid.Row="0">
            <DockPanel>
                <TextBlock Text="Оформление ремонта/ТО" Style="{StaticResource WhiteText}" Margin="20,0" VerticalAlignment="Center"/>
                <Button Content="Выход" DockPanel.Dock="Right" Background="Transparent" Foreground="White" Click="BtnExit_Click" Margin="0,0,20,0"/>
                <Button Content="Закрыть" DockPanel.Dock="Right" Background="Transparent" Foreground="White" Click="BtnClose_Click" Margin="0,0,10,0"/>
                <TextBlock Text="Механик" Style="{StaticResource WhiteText}" Margin="0,0,20,0" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
        <ScrollViewer Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Center" Width="700" Padding="20">
            <Border Style="{StaticResource Panel}">
                <StackPanel>
                    <Border Style="{StaticResource HeaderBar}">
                        <TextBlock Text="Оформление ремонтных работ" Style="{StaticResource WhiteText}" TextAlignment="Center"/>
                    </Border>
                    <Grid Margin="0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Label Content="Транспортное средство:"/>
                        <TextBox Grid.Column="1"/>
                        <Label Grid.Row="1" Content="Текущий пробег:"/>
                        <TextBox Grid.Row="1" Grid.Column="1"/>
                        <Label Grid.Row="2" Content="Дата последнего ТО:"/>
                        <TextBox Grid.Row="2" Grid.Column="1"/>
                    </Grid>
                    <Border Style="{StaticResource HeaderBar}" Margin="0,15">
                        <TextBlock Text="Параметры работ" Style="{StaticResource WhiteText}" TextAlignment="Center"/>
                    </Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Label Content="Тип события:"/>
                        <TextBox Grid.Column="1"/>
                        <Label Grid.Row="1" Content="Категория работ:"/>
                        <TextBox Grid.Row="1" Grid.Column="1"/>
                        <Label Grid.Row="2" Content="Вид работ:"/>
                        <TextBox Grid.Row="2" Grid.Column="1"/>
                        <Label Grid.Row="3" Content="Дата проведения:"/>
                        <TextBox Grid.Row="3" Grid.Column="1"/>
                        <Label Grid.Row="4" Content="Механик:"/>
                        <TextBox Grid.Row="4" Grid.Column="1"/>
                    </Grid>
                    <Border Style="{StaticResource HeaderBar}" Margin="0,15">
                        <TextBlock Text="Описание работ" Style="{StaticResource WhiteText}" TextAlignment="Center"/>
                    </Border>
                    <TextBox Height="80" TextWrapping="Wrap" Text="Замена передних и задних тормозных колодок. Проверка состояния тормозных дисков - износ 30%. Рекомендована замена тормозных дисков при следующем ТО."/>
                    <UniformGrid Columns="2" Margin="0,20,0,0">
                        <Button Content="Сохранить" Height="40"/>
                        <Button Content="Отмена" Height="40" Margin="10,0,0,0"/>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>