<Page x:Class="AutoTrek.Page05_Fueling"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgLight}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Background="{StaticResource BgDark}" Grid.Row="0">
            <DockPanel>
                <TextBlock Text="Регистрация заправки" Style="{StaticResource WhiteText}" Margin="20,0" VerticalAlignment="Center"/>
                <Button Content="Выход" DockPanel.Dock="Right" Background="Transparent" Foreground="White" Click="BtnExit_Click" Margin="0,0,20,0"/>
                <Button Content="Закрыть" DockPanel.Dock="Right" Background="Transparent" Foreground="White" Click="BtnClose_Click" Margin="0,0,10,0"/>
                <TextBlock Text="Диспетчер" Style="{StaticResource WhiteText}" Margin="0,0,20,0" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
        <ScrollViewer Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Center" Width="700" Padding="20">
            <Border Style="{StaticResource Panel}">
                <StackPanel>
                    <Border Style="{StaticResource HeaderBar}">
                        <TextBlock Text="Регистрация заправки ТС" Style="{StaticResource WhiteText}" TextAlignment="Center"/>
                    </Border>
                    <Grid Margin="0,10,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Транспортное средство:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"/>
                    </Grid>
                    <Border Style="{StaticResource HeaderBar}" Margin="0,0,0,15">
                        <TextBlock Text="Детали заправки" Style="{StaticResource WhiteText}" TextAlignment="Center"/>
                    </Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Label Content="Дата и время заправки:"/>
                        <TextBox Grid.Column="1"/>
                        <Label Grid.Row="1" Content="АЗС:"/>
                        <TextBox Grid.Row="1" Grid.Column="1"/>
                        <Label Grid.Row="2" Content="Тип топлива:"/>
                        <TextBox Grid.Row="2" Grid.Column="1"/>
                        <Label Grid.Row="3" Content="Объём заправки:"/>
                        <TextBox Grid.Row="3" Grid.Column="1"/>
                        <Label Grid.Row="4" Content="Цена за литр:"/>
                        <TextBox Grid.Row="4" Grid.Column="1"/>
                        <Label Grid.Row="5" Content="Стоимость заправки:" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                            <TextBox Width="150" IsEnabled="False"/>
                            <TextBlock Text="руб. (рассчитано)" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Label Grid.Row="6" Content="Показания одометра:"/>
                        <TextBox Grid.Row="6" Grid.Column="1"/>
                        <Label Grid.Row="7" Content="Номер чека/карты:"/>
                        <TextBox Grid.Row="7" Grid.Column="1"/>
                    </Grid>
                    <UniformGrid Columns="2" Margin="0,20,0,0">
                        <Button Content="Сохранить" Height="40"/>
                        <Button Content="Отмена" Height="40" Margin="10,0,0,0"/>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>