<Page x:Class="AutoTrek.Page01_Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgDark}">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
            <TextBlock Text="Планирование и контроль&#10;расходов автопарка" Style="{StaticResource WhiteText}" FontSize="24" TextAlignment="Center" Margin="0,0,0,30"/>
            <Border Style="{StaticResource Panel}">
                <StackPanel>
                    <TextBlock Text="Авторизация" FontSize="18" FontWeight="SemiBold" TextAlignment="Center" Margin="0,0,0,15"/>

                    <!-- Поле Логин с подписью -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Логин:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                        <TextBox Grid.Column="1" x:Name="TxtLogin" FontSize="14" Margin="0,15,0,11"/>
                    </Grid>

                    <!-- Поле Пароль с подписью -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Пароль:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                        <PasswordBox Grid.Column="1" x:Name="TxtPass" FontSize="14" Margin="0,10,0,8"/>
                    </Grid>

                    <CheckBox x:Name="ChkRemember" Content="Запомнить меня" Margin="0,0,0,15"/>
                    <Button Content="Войти" Click="BtnLogin_Click" Height="45" FontSize="16" FontWeight="SemiBold" Background="{StaticResource HeaderBg}" Foreground="White"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>